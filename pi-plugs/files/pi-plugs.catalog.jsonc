      ],
      "configFiles": [
        "extensions/readsubagent.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "tags": [
        "agent",
        "read-only"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "vettingagents",
      "title": "Vetting agents",
      "description": "Runs three independent read-only adversarial child agents for docs, plans, implementation results, diffs, and code review targets.",
      "entry": "extensions/vettingagents.ts",
      "pluginDeps": [
        "zz-subagent-runtime"
      ],
      "fileDeps": [
        "extensions/vettingagents.config.jsonc",
