          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "promptenrichsubagent",
      "title": "Prompt enrich subagent",
      "description": "Standalone, manually-triggered prompt-enrichment agent. /pe <prompt> runs a clarification/enrichment pass (using readsubagent for repo context) and returns enriched prompt options or clarifying questions. Independent of workflow mode; does not alter wf-clarifier.",
      "entry": "extensions/promptenrichsubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "zz-local-models",
