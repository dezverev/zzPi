        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": [
        "extensions/implementationsubagent.config.jsonc"
      ],
      "tags": [
        "agent",
        "implementation",
        "subagent"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "brainstormer",
      "title": "Solution brainstormer",
      "description": "Standalone read-only agent that researches and suggests structured solution options and tradeoffs.",
      "entry": "extensions/brainstormer.ts",
      "pluginDeps": ["zz-subagent-runtime", "readsubagent"],
      "fileDeps": [
        "extensions/brainstormer.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/design-loop-types.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": ["extensions/brainstormer.config.jsonc"],
      "tags": ["agent", "design", "standalone"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "designplanner",
      "title": "Design planner",
      "description": "Standalone read-only agent that turns one selected brainstorm solution into a staged technical design.",
      "entry": "extensions/designplanner.ts",
      "pluginDeps": ["zz-subagent-runtime", "readsubagent"],
      "fileDeps": [
        "extensions/designplanner.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/design-loop-types.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": ["extensions/designplanner.config.jsonc"],
      "tags": ["agent", "design", "standalone"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "design-loop",
      "title": "Design loop",
      "description": "Composes solution brainstorming and explicit single-solution selection into a staged technical design workflow.",
      "entry": "extensions/design-loop.ts",
      "pluginDeps": ["brainstormer", "designplanner"],
      "fileDeps": ["extensions/lib/agent-mode.ts", "extensions/lib/design-artifacts.ts", "extensions/lib/planning-artifact-paths.ts"],
      "configFiles": [],
      "tags": ["workflow", "brainstorming", "design"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "workflowmode",
      "title": "Workflow mode",
      "description": "Adds /workflowmode and input-focused Alt+W to clarify, enrich, brainstorm, select, design-plan, implementation-plan, then implement/review each plan stage, fill test gaps, and run whole-branch final review until green.",
      "entry": "extensions/workflowmode.ts",
      "pluginDeps": [
        "workflow-tree",
        "wf-clarifier",
        "wf-brainstormer",
        "wf-adversarialreview",
        "wf-designplan",
        "wf-impplanner",
        "wf-implementeragent",
        "wf-revieweragent",
        "wf-finalreviewagent",
        "wf-testeragent"
      ],
      "fileDeps": [
        "extensions/lib/workflow-tree-state.ts"
      ],
      "configFiles": [],
      "tags": [
        "workflow"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "readsubagent",
      "title": "Read subagent",
      "description": "Adds /readsubagent and a readsubagent tool for targeted file-inspection questions through a child Pi process.",
      "entry": "extensions/readsubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "zz-local-models"
      ],
      "fileDeps": [
