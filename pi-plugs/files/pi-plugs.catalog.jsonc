// Source of truth for the dependency-aware zzHostWebsite pi plug installer.
// Paths are relative to this .pi directory.
{
  "schemaVersion": 1,
  "commonFiles": [],
  "plugins": [
    {
      "id": "zz-plug-manager",
      "title": "zz plug manager",
      "description": "Internal command extension that installs, removes, updates, and dependency-resolves this repo-local pi plug bundle from inside pi.",
      "entry": "extensions/zz-plug-manager.ts",
      "internal": true,
      "pluginDeps": [
        "right-overlay-tiler",
        "zz-subagent-runtime"
      ],
      "fileDeps": [
        "extensions/zz-plug-manager.config.jsonc"
      ],
      "configFiles": [
        "extensions/zz-plug-manager.config.jsonc"
      ],
      "tags": [
        "manager",
        "internal"
      ]
    },
    {
      "id": "right-overlay-tiler",
      "title": "Right overlay tiler",
      "description": "Internal host for right-side overlay panes used by status/context/history extensions.",
      "entry": "extensions/00-right-overlay-tiler.ts",
      "internal": true,
      "pluginDeps": [],
      "fileDeps": [
        "extensions/right-overlay-tiler.config.jsonc",
        "extensions/lib/right-overlay-tiler.ts"
      ],
      "configFiles": [
        "extensions/right-overlay-tiler.config.jsonc"
      ],
      "tags": [
        "ui",
        "overlay",
        "internal"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "zz-subagent-runtime",
      "title": "zz subagent runtime",
      "description": "Internal shared child-Pi subagent helper library, endpoint config, and /zz-model-setup command for custom and bundled subagent extensions.",
      "entry": "extensions/00-zz-subagent-runtime.ts",
      "internal": true,
      "pluginDeps": [],
      "fileDeps": [
        "extensions/local-model-endpoints.config.jsonc",
        "extensions/lib/child-agent-model-options.ts"
      ],
      "configFiles": [
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "tags": [
        "agent",
        "runtime",
        "internal"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "zz-local-models",
      "title": "zz local models",
      "description": "Registers shared LM Studio models in Pi's normal /model picker.",
      "entry": "extensions/zzLocalModels.ts",
      "pluginDeps": [],
      "fileDeps": [
        "extensions/zzLocalModels.config.jsonc"
      ],
      "configFiles": [
        "extensions/zzLocalModels.config.jsonc"
      ],
      "tags": [
        "model",
        "local-model",
        "lm-studio"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "context-tools",
      "title": "Context tools",
      "description": "Shows context/tool usage accounting in a right-side pane.",
      "entry": "extensions/context-tools.ts",
      "pluginDeps": [
        "right-overlay-tiler"
      ],
      "fileDeps": [
        "extensions/context-tools.config.jsonc",
        "extensions/lib/right-overlay-tiler.ts"
      ],
      "configFiles": [
        "extensions/context-tools.config.jsonc"
      ],
      "tags": [
        "ui",
        "context",
        "overlay"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "git-status",
      "title": "Git status",
      "description": "Shows a VS Code-style Git branch/change summary in the footer and right-side details pane.",
      "entry": "extensions/git-status.ts",
      "pluginDeps": [
        "right-overlay-tiler"
      ],
      "fileDeps": [
        "extensions/git-status.config.jsonc",
        "extensions/lib/right-overlay-tiler.ts"
      ],
      "configFiles": [
        "extensions/git-status.config.jsonc"
      ],
      "tags": [
        "git",
        "ui",
        "overlay"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "pi-context",
      "title": "PI.md context",
      "description": "Strips built-in AGENTS.md/CLAUDE.md project context and injects discovered PI.md files instead.",
      "entry": "extensions/pi-context.ts",
      "pluginDeps": [],
      "fileDeps": [
        "extensions/pi-context.config.jsonc"
      ],
      "configFiles": [
        "extensions/pi-context.config.jsonc"
      ],
      "tags": [
        "context"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "debuggersubagent",
      "title": "Debugger subagent",
      "description": "Provides standalone read-only root-cause diagnosis for bugs, failures, regressions, flaky behavior, and suspicious runtime results.",
      "entry": "extensions/debuggersubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "readsubagent"
      ],
      "fileDeps": [
        "extensions/debuggersubagent.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": [
        "extensions/debuggersubagent.config.jsonc"
      ],
      "tags": [
        "agent",
        "debugging",
        "subagent"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "implementationsubagent",
      "title": "Implementation subagent",
      "description": "Provides a main-agent-controlled implementation worker for one bounded piece from a Markdown implementation document, with a persistent progress ledger and nested read/debug tools.",
      "entry": "extensions/implementationsubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "readsubagent",
        "debuggersubagent"
      ],
      "fileDeps": [
        "extensions/implementationsubagent.config.jsonc",
        "extensions/lib/agent-mode.ts",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/implementation-docs.ts",
        "extensions/lib/planning-artifact-paths.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": [
        "extensions/implementationsubagent.config.jsonc"
      ],
      "tags": [
        "agent",
        "implementation",
        "subagent"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "brainstormer",
      "title": "Solution brainstormer",
      "description": "Standalone read-only agent that researches and suggests structured solution options and tradeoffs.",
      "entry": "extensions/brainstormer.ts",
      "pluginDeps": ["zz-subagent-runtime", "readsubagent"],
      "fileDeps": [
        "extensions/brainstormer.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/design-loop-types.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": ["extensions/brainstormer.config.jsonc"],
      "tags": ["agent", "design", "standalone"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "designplanner",
      "title": "Design planner",
      "description": "Standalone read-only agent that turns one selected brainstorm solution into a staged technical design.",
      "entry": "extensions/designplanner.ts",
      "pluginDeps": ["zz-subagent-runtime", "readsubagent"],
      "fileDeps": [
        "extensions/designplanner.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/design-loop-types.ts",
        "extensions/lib/standalone-agent-common.ts"
      ],
      "configFiles": ["extensions/designplanner.config.jsonc"],
      "tags": ["agent", "design", "standalone"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "design-loop",
      "title": "Design loop",
      "description": "Composes solution brainstorming and explicit single-solution selection into a staged technical design workflow.",
      "entry": "extensions/design-loop.ts",
      "pluginDeps": ["brainstormer", "designplanner"],
      "fileDeps": ["extensions/lib/agent-mode.ts", "extensions/lib/design-artifacts.ts", "extensions/lib/planning-artifact-paths.ts"],
      "configFiles": [],
      "tags": ["workflow", "brainstorming", "design"],
      "sharedDeps": [{"id": "zz-lib", "minVersion": "1.0.0"}]
    },
    {
      "id": "readsubagent",
      "title": "Read subagent",
      "description": "Adds /readsubagent and a readsubagent tool for targeted file-inspection questions through a child Pi process.",
      "entry": "extensions/readsubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "zz-local-models"
      ],
      "fileDeps": [
        "extensions/readsubagent.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc",
        "extensions/lib/agent-mode.ts"
      ],
      "configFiles": [
        "extensions/readsubagent.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "tags": [
        "agent",
        "read-only"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "vettingagents",
      "title": "Vetting agents",
      "description": "Runs three independent read-only adversarial child agents for docs, plans, implementation results, diffs, and code review targets.",
      "entry": "extensions/vettingagents.ts",
      "pluginDeps": [
        "zz-subagent-runtime"
      ],
      "fileDeps": [
        "extensions/vettingagents.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc",
        "extensions/lib/child-agent-model-options.ts",
        "extensions/lib/agent-mode.ts"
      ],
      "configFiles": [
        "extensions/vettingagents.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "tags": [
        "agent",
        "vetting",
        "docs"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "promptenrichsubagent",
      "title": "Prompt enrich subagent",
      "description": "Standalone, manually-triggered prompt-enrichment agent. /pe <prompt> runs a clarification/enrichment pass (using readsubagent for repo context) and returns enriched prompt options or clarifying questions.",
      "entry": "extensions/promptenrichsubagent.ts",
      "pluginDeps": [
        "zz-subagent-runtime",
        "zz-local-models",
        "readsubagent"
      ],
      "fileDeps": [
        "extensions/promptenrichsubagent.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "configFiles": [
        "extensions/promptenrichsubagent.config.jsonc",
        "extensions/local-model-endpoints.config.jsonc"
      ],
      "tags": [
        "agent",
        "enrichment"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    },
    {
      "id": "tetris",
      "title": "Tetris",
      "description": "Adds /tetris, an overlay Tetris game for waiting during agent runs.",
      "entry": "extensions/tetris.ts",
      "pluginDeps": [],
      "fileDeps": [
        "extensions/tetris.config.jsonc"
      ],
      "configFiles": [
        "extensions/tetris.config.jsonc"
      ],
      "tags": [
        "game",
        "ui"
      ],
      "sharedDeps": [
        {
          "id": "zz-lib",
          "minVersion": "1.0.0"
        }
      ]
    }
  ]
}
