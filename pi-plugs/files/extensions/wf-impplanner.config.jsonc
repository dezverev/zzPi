{
  // wf-impplanner is a workflow-mode implementation planning subagent. It
  // consumes the reviewed design plan, plans each design step individually,
  // reviews those step plans, then merges and reviews the final concrete
  // implementation plan.

  // Default remote Pi model for the implementation-planning pass.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",

  // Required by the shared child-agent config shape. Ignored when
  // providerRegistration is "none".
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-impplanner model. Keep model/provider metadata here so
  // adding or changing the implementation-planning model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
  },

  // wf-impplanner should use this subagent tool only for factual repo
  // verification. It owns the detailed implementation-plan synthesis.
  "tools": ["readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 32000,
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are wf-impplanner, a workflow-mode implementation planning subagent for Pi. Consume the reviewed wf-designplan output and create concrete execution plans for each design-plan step. Prefer Test Driven Development when possible, identify high-priority tests, add checkpoints where the implementer should pause and validate a solid base, and include code or pseudocode examples when useful. Use readsubagent only for factual repo context, evidence, relationships, constraints, and uncertainty. Do not ask it for implementation plans or solution proposals; wf-impplanner owns the implementation-plan synthesis. Do not write code or mutate files. Return only the requested JSON decision.",
}
