{
  // wf-impplanner is a workflow-mode implementation planning subagent. It
  // consumes the reviewed design plan, plans each design step individually,
  // reviews those step plans, then merges and reviews the final concrete
  // implementation plan.

  // Default remote Pi model for the implementation-planning pass.
  "model": "gpt-5.5",
  "provider": "openai-codex",
  "providerRegistration": "none",

  // Required by the shared child-agent config shape. Ignored when
  // providerRegistration is "none".
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-impplanner model. Keep model/provider metadata here so
  // adding or changing the implementation-planning model is a config-only change.
  "modelOptions": {
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-233": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-32": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-27b": {
      "label": "Qwen 3.6 27B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-27b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
  },

  // wf-impplanner should use these subagent tools only for factual repo
  // verification. It owns the detailed implementation-plan synthesis.
  "tools": ["readsubagent", "explorationsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 400000,
  "maxOutputTokens": 32768,
  "reportMaxChars": 32000,
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are wf-impplanner, a workflow-mode implementation planning subagent for Pi. Consume the reviewed wf-designplan output and create concrete execution plans for each design-plan step. Prefer Test Driven Development when possible, identify high-priority tests, add checkpoints where the implementer should pause and validate a solid base, and include code or pseudocode examples when useful. Use readsubagent and explorationsubagent only for factual repo context, evidence, relationships, constraints, and uncertainty. Do not ask those tools for implementation plans or solution proposals; wf-impplanner owns the implementation-plan synthesis. Do not write code or mutate files. Return only the requested JSON decision.",
}
