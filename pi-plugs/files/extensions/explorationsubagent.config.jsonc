{
  // Explorationsubagent model choices carry their own endpoint/provider metadata.
  // /explorationsubagent model switches between local OpenAI-compatible endpoints
  // and remote Pi providers. The shared local-model-endpoints config is only a
  // fallback for configs/options that do not define an endpoint.

  // Model id served by LM Studio.
  "model": "qwen/qwen3.6-35b-a3b",

  // Provider name used by the child process. The visible /model provider is
  // registered by zzLocalModels, not by explorationsubagent itself.
  "provider": "lm-studio",
  "providerRegistration": "none",

  // Optional Pi model selector to pass directly to the child process.
  // Leave empty to use "<provider>/<model>" from the settings above.
  "modelSelector": "",

  // Choices shown by /explorationsubagent model. Keep model-specific provider/model
  // metadata here so adding new explorationsubagent models is a config-only change.
  // The object key is the stable selection id persisted in the session branch.
  "modelOptions": {
    "qwen": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 16000,
      "thinking": "off",
      "tools": ["read", "bash", "grep", "find", "ls"],
    },
    "qwen-233": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 16000,
      "thinking": "off",
      "tools": ["read", "bash", "grep", "find", "ls"],
    },
    "qwen-32": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 16000,
      "thinking": "off",
      "tools": ["read", "bash", "grep", "find", "ls"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 16000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls"],
    },
  },

  // Tools available to the child Pi process. Exploration is read-only, but includes
  // bash so the child can run context-efficient discovery commands like rg/find/ls.
  "tools": ["read", "bash", "grep", "find", "ls"],

  // Child process limits and custom model metadata.
  "requestTimeoutMs": 1800000,
  "contextWindow": 262144,
  "maxOutputTokens": 32768,

  // Hard cap for final report characters injected back into the main conversation.
  // Individual tool calls can request a lower maxReportChars budget.
  "reportMaxChars": 16000,

  // Thinking level passed to the child process.
  "thinking": "off",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are a read-only repo exploration subagent spawned by Pi. The parent agent delegates exploratory discovery when broad rg/find/ls/bash searches would waste parent context. Use read-only tools as needed to map likely files, symbols, call sites, configuration, and relationships. You may use bash only for read-only discovery commands such as rg, find, ls, pwd, git status/log/diff --stat/--name-only, and similar inspection commands. Do not edit or write files and do not run destructive commands. Do not create implementation plans, solution proposals, edit strategies, code-review judgments, bug findings, correctness assessments, control-flow/type-safety analysis, or accept/reject recommendations. Your job is factual repo archaeology, relationships, evidence, and uncertainty only. If the parent asks for hard logic, review, or whether code is correct/acceptable, state that this is outside explorationsubagent scope and return only the factual map/evidence that would support a separate review. Prefer context-efficient searches: rg -l, rg --count, rg -n -m, --glob filters, and narrowed paths before reading files. Never return raw grep/find dumps, large command transcripts, whole files, or broad diffs. Return a concise exploration map with direct answer, relevant files, key symbols/patterns, how they connect, searches tried, uncertainty, and possible next factual reads/searches.",
}
