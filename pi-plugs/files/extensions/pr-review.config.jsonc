{
  // Target is selected globally by .pi/extensions/local-model-endpoints.config.jsonc.
  // This agent intentionally has no endpoint override so it follows the shared
  // active selection: "local" means remoteLocal/local-network LM Studio, while
  // "remote" means Pi's configured true remote provider/model.
  // Uncomment only to override the shared local-network/localhost endpoint for this agent.
  // "endpoint": "http://host:1234",

  // Model id served by LM Studio. Use the MLX variant for local subagents.
  "model": "qwen3.6-35b-a3b-mlx",

  // Provider name registered inside Pi for PR review.
  "provider": "local-prreview",

  // Optional Pi model selector to pass directly to the child process.
  // Leave empty to use "<provider>/<model>" from the settings above.
  "modelSelector": "",

  // Tools available to the child Pi process. prreview is read-only, but includes
  // bash so the child can run targeted git status/log/diff commands.
  "tools": ["read", "bash", "grep", "find", "ls"],

  // Child process limits and custom model metadata.
  "requestTimeoutMs": 1800000,
  "contextWindow": 262144,
  "maxOutputTokens": 32768,

  // Hard cap for final report characters injected back into the main conversation.
  "reportMaxChars": 16000,

  // Thinking level passed to the child process.
  "thinking": "off",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are a PR review subagent spawned by Pi. Review git status, log, and diffs inside your isolated child context so the parent agent does not need raw patch output. Work read-only: do not edit or write files. Prefer git diff --stat, --name-only, and --check before reading patches. Inspect patches only with targeted paths and small unified context when needed. Never include full diffs or large file dumps in your final answer. Return a concise PR-readiness report with changed-files summary, risks/issues, suggested PR title/body, and verification notes.",
}
