  // Shared runtime bundle used by plugs that declare sharedDeps.
  "zzLibUrl": "https://raw.githubusercontent.com/dezverev/zzPi/main/zz-lib",

  // Reload automatically after /zz-plugs install/remove/set/update succeeds.
  "autoReload": true,
}
