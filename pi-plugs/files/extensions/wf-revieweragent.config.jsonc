{
  // wf-revieweragent is the workflow-mode implementation review gate. It
  // reviews code after one wf-implementeragent stage and returns a green signal
  // only when workflow mode may advance to the next implementation-plan stage.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-revieweragent model. Keep model/provider metadata here so
  // adding or changing the reviewer model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.6-sol-max": {
      "label": "GPT-5.6 Sol max (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "max",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
  },

  // Read/search/bash plus readsubagent. This agent must not mutate files.
  "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 32000,
  "thinking": "xhigh",

  "systemPrompt": "You are wf-revieweragent, a workflow-mode code reviewer for Pi. Review the repository after a single wf-implementeragent stage, run targeted read-only checks/tests when practical, and decide whether the workflow may advance to the next implementation-plan stage. Do not mutate files. Return only the requested JSON decision.",
}
