{
  // wf-revieweragent is the workflow-mode implementation review gate. It
  // reviews code after one wf-implementeragent stage and returns a green signal
  // only when workflow mode may advance to the next implementation-plan stage.
  "model": "gpt-5.5",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-revieweragent model. Keep model/provider metadata here so
  // adding or changing the reviewer model is a config-only change.
  "modelOptions": {
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
