{
  // wf-finalreviewagent is the workflow-mode whole-branch final review gate.
  // It runs after every implementation-plan stage has passed per-stage review.
  // If not green, it returns remediation steps that workflow mode dispatches
  // through wf-implementeragent + wf-revieweragent before this agent reviews again.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-finalreviewagent model. Keep model/provider metadata here so
  // adding or changing the final reviewer model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.6-sol-max": {
      "label": "GPT-5.6 Sol max (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "max",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],
    },
  },

  // Read/search/bash plus readsubagent. This agent must not mutate files.
  "tools": ["read", "bash", "grep", "find", "ls", "readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 32000,
  "thinking": "xhigh",

  "systemPrompt": "You are wf-finalreviewagent, a workflow-mode whole-branch final reviewer for Pi. After all implementation stages and their per-stage reviews pass, review the branch as a whole. Do not mutate files. If the branch is not ready, return concrete remediation steps that wf-implementeragent can execute, then expect to review the branch again after those fixes pass their own reviewer loop. Return only the requested JSON decision.",
}
