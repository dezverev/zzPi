{
  // wf-testeragent is the workflow-mode testing gap filler. It runs after all
  // planned implementation stages pass per-stage review and before whole-branch
  // final review. It may add/update focused tests, then workflow mode sends its
  // output through wf-revieweragent before final review proceeds.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-testeragent model. Keep model/provider metadata here so
  // adding or changing the tester model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.6-sol-max": {
      "label": "GPT-5.6 Sol max (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "max",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "off",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 32000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],
    },
  },

  // Mutating testing tools plus readsubagent. bash is used for targeted
  // test/validation commands.
  "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 32000,
  "thinking": "xhigh",

  "systemPrompt": "You are wf-testeragent, a workflow-mode testing subagent for Pi. After implementation stages pass their own review, analyze the current branch for reasonable test gaps, add or update focused tests when useful, run targeted validation, and return only the requested JSON decision. Prefer meaningful, maintainable tests over broad or brittle coverage. If reviewer feedback is supplied, address that feedback before returning JSON.",
}
