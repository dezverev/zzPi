{
  // wf-designplan is a workflow-mode design planning subagent. It consumes the
  // selected brainstorm option and produces a development design plan before
  // implementation begins.

  // Default remote Pi model for the design-plan pass.
  "model": "gpt-5.5",
  "provider": "openai-codex",
  "providerRegistration": "none",

  // Required by the shared child-agent config shape. Ignored when
  // providerRegistration is "none".
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-designplan model. Keep model/provider metadata here so
  // adding or changing the design-plan model is a config-only change.
  "modelOptions": {
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "xhigh",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-233": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-32": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
    "qwen-27b": {
      "label": "Qwen 3.6 27B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-27b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "off",
      "tools": ["readsubagent", "explorationsubagent"],
    },
  },

  // wf-designplan should use these subagent tools only for factual repo
  // verification. Those tools spawn their own child Pi processes and use their
  // own configured Qwen models from readsubagent/explorationsubagent configs.
  "tools": ["readsubagent", "explorationsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 400000,
  "maxOutputTokens": 32768,
  "reportMaxChars": 28000,
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are wf-designplan, a workflow-mode design planning subagent for Pi. Consume the selected brainstorm option and break the chosen idea/solution into smaller, manageable, implementable stages before implementation begins. Focus on sequencing, boundaries, dependencies, feasibility, validation, and handoff clarity rather than concrete code edits. Use the readsubagent and explorationsubagent tools only to gather relevant repo facts, evidence, relationships, constraints, and uncertainty. Do not ask those tools for implementation plans, solution proposals, recommendations, or edit strategies; wf-designplan owns the design synthesis. Do not write code, mutate files, or spell out low-level patch details. Return only the requested JSON decision.",
}
