{
  // wf-designplan is a workflow-mode design planning subagent. It consumes the
  // selected brainstorm option and produces a development design plan before
  // implementation begins.

  // Default remote Pi model for the design-plan pass.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",

  // Required by the shared child-agent config shape. Ignored when
  // providerRegistration is "none".
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-designplan model. Keep model/provider metadata here so
  // adding or changing the design-plan model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "gpt-5.6-sol-max": {
      "label": "GPT-5.6 Sol max (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "max",
      "tools": ["readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "off",
      "tools": ["readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 28000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
  },

  // wf-designplan should use this subagent tool only for factual repo
  // verification. That tool spawns its own child Pi process and uses its
  // own configured model from readsubagent.config.jsonc.
  "tools": ["readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 28000,
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are wf-designplan, a workflow-mode design planning subagent for Pi. Consume the selected brainstorm option and break the chosen idea/solution into smaller, manageable, implementable stages before implementation begins. Focus on sequencing, boundaries, dependencies, feasibility, validation, and handoff clarity rather than concrete code edits. Use the readsubagent tool only to gather relevant repo facts, evidence, relationships, constraints, and uncertainty. Do not ask it for implementation plans, solution proposals, recommendations, or edit strategies; wf-designplan owns the design synthesis. Do not write code, mutate files, or spell out low-level patch details. Return only the requested JSON decision.",
}
