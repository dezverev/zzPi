{
  // Registers shared LM Studio models in Pi's normal /model picker.
  // Run /zz-model-setup setup after install to use your own default endpoint/model.
  "enabled": true,
  "provider": "lm-studio",
  "name": "LM Studio",
  "endpoint": "http://127.0.0.1:1234",
  "apiKey": "lm-studio",

  // Defaults applied to model entries unless overridden per model.
  "contextWindow": 127000,
  "maxTokens": 32768,
  "reasoning": true,

  "models": [
    {
      "id": "qwen/qwen3.6-35b-a3b",
      "name": "Qwen 3.6 35B A3B via LM Studio (default long context)",
      "contextWindow": 250000,
      "maxTokens": 32768
    },
    {
      "id": "qwen/qwen3.6-27b",
      "name": "Qwen 3.6 27B via LM Studio (long context)",
      "contextWindow": 250000,
      "maxTokens": 32768
    },
    {
      "id": "qwen3.6-27b-rust-v1.mlx",
      "name": "Qwen 3.6 27B Rust v1 MLX via LM Studio",
      "contextWindow": 120000,
      "maxTokens": 32768,
      "reasoning": false
    }
  ]
}
