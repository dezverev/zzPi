{
  // Main-agent-controlled implementation worker. It executes one bounded piece
  // from a Markdown implementation document and maintains a persistent ledger.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  "modelOptions": {
    "gpt-5.6-sol-max": {
      "label": "GPT-5.6 Sol max (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 2700000,
      "reportMaxChars": 40000,
      "thinking": "max",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "debuggersubagent"],
    },
    "gpt-5.6-sol-xhigh": {
