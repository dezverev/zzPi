{
  // implementationsubagent is a first-class implementation worker for Pi.
  // /zzSubagentImplemention on (or Alt+S) tells the parent model to delegate
  // involved implementation tasks to this child agent with a concrete plan/context.
  "enabledByDefault": false,

  "model": "gpt-5.5",
  "provider": "openai-codex",
  "providerRegistration": "none",
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /zzSubagentImplemention model. Keep model/provider metadata
  // here so changing implementation subagent models is a config-only change.
  "modelOptions": {
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "endpoint": "http://127.0.0.1:1234",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 40000,
      "thinking": "xhigh",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 40000,
      "thinking": "off",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-233": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 40000,
      "thinking": "off",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
    "qwen-35b-a3b-32": {
      "label": "Qwen 3.6 35B A3B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:11444",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 40000,
      "thinking": "off",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
    "qwen-27b": {
      "label": "Qwen 3.6 27B on 127.0.0.1 (LM Studio)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-27b",
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 40000,
      "thinking": "off",
      "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],
    },
  },

  // Mutating implementation tools. bash is for targeted tests/checks;
  // readsubagent/explorationsubagent are available for factual repo context.
  "tools": ["read", "bash", "edit", "write", "grep", "find", "ls", "readsubagent", "explorationsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 400000,
  "maxOutputTokens": 32768,
  "reportMaxChars": 40000,
  "thinking": "xhigh",

  "systemPrompt": "You are implementationsubagent, a Pi implementation subagent. Work autonomously on the delegated implementation task using repository tools as needed. Follow repo PI.md/AGENTS.md instructions. Keep scope tight to the supplied plan and context, edit/write files when needed, run targeted validation when practical, and return a concise structured report with status, files changed, tests/checks run, validation result, blockers/questions, and notes. Do not perform git commits, pushes, branch operations, PR operations, broad code review, or unrelated follow-up work unless explicitly requested.",
}
