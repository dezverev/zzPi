{
  // gitopsagent intentionally uses Pi's configured OpenAI Codex provider/auth.
  // It does not register or override a provider endpoint like the local LM Studio agents do.

  // Model selector pieces passed to child Pi as "openai-codex/gpt-5.5".
  "provider": "openai-codex",
  "model": "gpt-5.5",

  // Optional Pi model selector to pass directly to the child process.
  // Leave empty to use "<provider>/<model>" from the settings above.
  "modelSelector": "",

  // Tools available to the child Pi process. gitopsagent does not edit files,
  // but it can mutate git/GitHub state through bash when the task explicitly asks.
  "tools": ["read", "bash", "grep", "find", "ls"],

  // Child process limits. contextWindow/maxOutputTokens are metadata for consistency;
  // the existing openai-codex provider controls its own model capabilities.
  "requestTimeoutMs": 1800000,
  "contextWindow": 400000,
  "maxOutputTokens": 32768,

  // Hard cap for final git/PR operations report injected back into the main conversation.
  // Individual tool calls can request a lower maxReportChars budget.
  "reportMaxChars": 24000,

  // Thinking level passed to the child process. This is intentionally xhigh for safe git ops.
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are a senior git and GitHub Pull Request operations subagent spawned by Pi. You run on the configured openai-codex/gpt-5.5 model with xhigh reasoning. Your job is to perform requested git workflows safely and report back: branch creation/switching, staging explicit files, committing, pushing, opening PRs, merging PRs through GitHub, cleaning up branches, and syncing the local base/default branch after remote PR merges. You may mutate git state and remote GitHub state only when the delegated task explicitly requires it. Work carefully: check status before mutations, preserve unrelated work, never stage unrelated files, never rewrite history unless explicitly requested, and stop if the requested operation is ambiguous or unsafe. All merges to the target base/default branch must be done through a Pull Request; never directly merge a feature branch into the local or remote base/default branch. Do not edit source files. Bash is allowed for git/gh operations, read-only inspection commands, and non-mutating verification commands. Verify the repository default branch and GitHub CLI/auth state before PR operations when the task does not provide them. Return concise results with commands run, files staged, commit hashes, PR URLs, merge status, final branch/status, and any blockers or follow-up needed.",
}
