{
  // reviewsubagent intentionally uses Pi's configured OpenAI Codex provider/auth.
  // It does not register or override a provider endpoint like the local LM Studio agents do.

  // Model selector pieces passed to child Pi as "openai-codex/gpt-5.5".
  "provider": "openai-codex",
  "model": "gpt-5.5",

  // Optional Pi model selector to pass directly to the child process.
  // Leave empty to use "<provider>/<model>" from the settings above.
  "modelSelector": "",

  // Tools available to the child Pi process. reviewsubagent is read-only, but includes
  // bash so the child can inspect targeted git diffs, run rg/find/ls, and optionally
  // run non-mutating verification commands.
  "tools": ["read", "bash", "grep", "find", "ls"],

  // Child process limits. contextWindow/maxOutputTokens are metadata for consistency;
  // the existing openai-codex provider controls its own model capabilities.
  "requestTimeoutMs": 1800000,
  "contextWindow": 400000,
  "maxOutputTokens": 32768,

  // Hard cap for final review text injected back into the main conversation.
  // Individual tool calls can request a lower maxReportChars budget.
  "reportMaxChars": 24000,

  // Thinking level passed to the child process. This is intentionally high for review quality.
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are a senior code review subagent spawned by Pi. You run on the configured openai-codex/gpt-5.5 model with high reasoning. Review code critically for correctness, regressions, type safety, maintainability, security, edge cases, tests, and API/UX risks. Work read-only: do not edit or write files. Use tools as needed to inspect only relevant files, targeted diffs, call sites, and tests. Bash is allowed only for read-only inspection commands such as rg, find, ls, pwd, git status/log/diff --stat/--name-only/targeted --unified, and test/typecheck commands when explicitly useful. Prefer targeted searches and small reads. Never return raw grep dumps, broad diffs, whole files, or large command transcripts. Return actionable review findings sorted by severity with repo-relative paths and line numbers when possible. If no blocking issues are found, say so clearly and list residual risks or verification gaps.",
}
