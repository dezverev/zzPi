{
  // wf-adversarialreview is a workflow-mode review gate. It adversarially
  // checks selected wf-* stage outputs before they are shown as final
  // user-facing workflow output.

  // Default remote Pi model for the review pass.
  "model": "gpt-5.6-sol",
  "provider": "openai-codex",
  "providerRegistration": "none",

  // Required by the shared child-agent config shape. Ignored when
  // providerRegistration is "none".
  "endpoint": "http://127.0.0.1:1234",

  // Choices shown by /wf-adversarialreview model. Keep model/provider metadata
  // here so adding or changing the reviewer model is a config-only change.
  "modelOptions": {
    "gpt-5.6-sol-xhigh": {
      "label": "GPT-5.6 Sol xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.6-sol",
      "contextWindow": 272000,
      "maxOutputTokens": 128000,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 20000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "gpt-5.5-xhigh": {
      "label": "GPT-5.5 xhigh (openai-codex)",
      "provider": "openai-codex",
      "providerRegistration": "none",
      "model": "gpt-5.5",
      "contextWindow": 400000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 20000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
    "qwen-35b-a3b": {
      "label": "Qwen 3.6 35B A3B via 127.0.0.1:1234 proxy (telemetry)",
      "provider": "lm-studio",
      "providerRegistration": "none",
      "endpoint": "http://127.0.0.1:1234",
      "model": "qwen/qwen3.6-35b-a3b",
      "contextWindow": 127000,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 20000,
      "thinking": "off",
      "tools": ["readsubagent"],
    },
    "glm-5p2-xhigh": {
      "label": "GLM 5.2 xhigh (fireworks)",
      "provider": "fireworks",
      "providerRegistration": "none",
      "model": "accounts/fireworks/models/glm-5p2",
      "contextWindow": 1048575,
      "maxOutputTokens": 32768,
      "requestTimeoutMs": 1800000,
      "reportMaxChars": 20000,
      "thinking": "xhigh",
      "tools": ["readsubagent"],
    },
  },

  // wf-adversarialreview should use this subagent tool only for factual repo
  // verification. That tool spawns its own child Pi process and uses its
  // own configured model from readsubagent.config.jsonc.
  "tools": ["readsubagent"],

  "requestTimeoutMs": 1800000,
  "contextWindow": 272000,
  "maxOutputTokens": 128000,
  "reportMaxChars": 20000,
  "thinking": "xhigh",

  // Extra instructions appended to the child Pi system prompt.
  "systemPrompt": "You are wf-adversarialreview, a workflow-mode review gate for Pi. Adversarially review selected wf-* stage outputs before they are shown as final user-facing workflow output. Use the readsubagent tool only to gather relevant repo facts, evidence, relationships, constraints, and uncertainty. Do not ask it for implementation plans, solution proposals, recommendations, or edit strategies. Preserve the reviewed stage's expected output schema in reviewedOutput. Return only the requested JSON review envelope.",
}
